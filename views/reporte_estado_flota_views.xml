<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_opermaq_reporte_estado_flota_list" model="ir.ui.view">
        <field name="name">opermaq.reporte.estado.flota.list</field>
        <field name="model">opermaq.reporte.estado.flota</field>
        <field name="arch" type="xml">
            <list string="Detalle de Flota">
                <field name="equipment_id"/>
                <field name="estado" widget="badge" decoration-success="estado == 'stand_by'" decoration-warning="estado == 'alquilado'"/>
            </list>
        </field>
    </record>

    <record id="view_opermaq_reporte_estado_flota_graph" model="ir.ui.view">
        <field name="name">opermaq.reporte.estado.flota.graph</field>
        <field name="model">opermaq.reporte.estado.flota</field>
        <field name="arch" type="xml">
            <graph string="Disponibilidad de Flota" type="pie">
                <field name="estado"/>
            </graph>
        </field>
    </record>

    <record id="action_opermaq_reporte_estado_flota" model="ir.actions.act_window">
        <field name="name">Disponibilidad de Equipos</field>
        <field name="res_model">opermaq.reporte.estado.flota</field>
        <field name="view_mode">graph,list</field>
    </record>

    <menuitem id="menu_opermaq_flota_reportes_estado" 
              name="Alquilado vs Stand By" 
              parent="menu_opermaq_flota_reportes" 
              action="action_opermaq_reporte_estado_flota" 
              sequence="20"/>
</odoo>